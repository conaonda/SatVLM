# ═══════════════════════════════════════════════════════════════
# Satellite VLM API 환경 설정
# 이 파일을 복사하여 .env 로 저장 후 값을 채워주세요
# ═══════════════════════════════════════════════════════════════

# ── 모델 백엔드 ─────────────────────────────────────────────────
# geochat   : 위성영상 특화, 즉시 사용 가능 (권장 시작점)
# qwen2_vl  : 고성능 범용, fine-tuning 후 권장
# internvl2 : 고성능 오픈소스 대안
MODEL_BACKEND=geochat

# ── 모델 경로 (로컬 다운로드 후 경로 설정) ──────────────────────
# scripts/download_model.py 실행 후 채워주세요
GEOCHAT_LOCAL_PATH=./models/geochat-7b
QWEN2_VL_LOCAL_PATH=./models/qwen2-vl-7b
INTERNVL2_LOCAL_PATH=./models/internvl2-8b

# ── GPU 설정 ─────────────────────────────────────────────────────
DEVICE=cuda                    # cuda | cpu | cuda:0
TORCH_DTYPE=float16            # float16 | bfloat16 | float32

# ── 추론 파라미터 ────────────────────────────────────────────────
MAX_NEW_TOKENS=1024
TEMPERATURE=0.1                # 낮을수록 결정적 (분석용)
TOP_P=0.9

# ── 이미지 설정 ──────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=50
IMAGE_RESIZE=1024              # 모델 입력 최대 해상도
SUPPORT_GEOTIFF=true           # GeoTIFF 지원 (rasterio 필요)

# ── 서버 설정 ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1                      # GPU 1장 → 워커 1개

# ── 응답 언어 ────────────────────────────────────────────────────
DEFAULT_LANGUAGE=ko            # ko | en

# ── Vertex AI (fine-tuning 전용, 에어갭 서버에는 불필요) ──────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_STAGING_BUCKET=
